@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
if(@KF6Mime_FOUND@)
    find_dependency(
        KF6Mime
        "@KF_MIN_VERSION@"
    )
else()
    find_dependency(
        KPim6Mime
        "@KPIM_MIME_VERSION@"
    )
    if(NOT TARGET KF6::Mime)
        add_library(KF6::Mime ALIAS KPim6::Mime)
    endif()
endif()
find_dependency(
    KPim6IdentityManagementCore
    "@IDENTITYMANAGEMENT_LIB_VERSION@"
)
find_dependency(
    KPim6AkonadiCalendar
    "@AKONADICALENDAR_LIB_VERSION@"
)
find_dependency(
    Qt6PrintSupport
    "@QT_REQUIRED_VERSION@"
)
include("${CMAKE_CURRENT_LIST_DIR}/KPim6CalendarSupportTargets.cmake")
